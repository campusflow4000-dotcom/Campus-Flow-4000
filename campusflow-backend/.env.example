# ===== CampusFlow backend env =====
# Copy this file to ".env" and fill in real values. NEVER commit .env to GitHub.

PORT=4000

# ---- Supabase (Person 1 fills, shares URL + anon key with P3) ----
SUPABASE_URL=https://YOUR-PROJECT.supabase.co
SUPABASE_SERVICE_KEY=your-service-role-key   # server-side only, full access
SUPABASE_ANON_KEY=your-anon-key              # give THIS one to P3 for the frontend

# ---- Groq AI (console.groq.com -> API Keys) ----
GROQ_API_KEY=gsk_xxxxxxxxxxxxxxxxxxxx
GROQ_MODEL=llama-3.1-8b-instant              # fast demo model; swap to llama-3.3-70b-versatile for quality

# ---- n8n webhooks (Person 2 creates these, pastes the URLs here) ----
N8N_DEADLINE_WEBHOOK=https://YOUR-N8N.app.n8n.cloud/webhook-test/deadline
N8N_NOTICE_WEBHOOK=https://YOUR-N8N.app.n8n.cloud/webhook-test/notice

# CORS: your frontend dev origin (Vite default)
FRONTEND_ORIGIN=http://localhost:5173
